{
  "name": "room-axioms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "pnpm --filter @room-axioms/web dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "preview": "pnpm --filter @room-axioms/web preview",
    "authoring": "pnpm --filter @room-axioms/authoring cli"
  }
}
