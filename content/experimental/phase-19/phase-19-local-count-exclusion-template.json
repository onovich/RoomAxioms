    "mirror",
    "guest"
  ],
  "guestCount": 2,
  "rules": [
    {
      "id": "R1",
      "type": "globalCount",
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 2
      },
      "presentation": {
        "title": "Guest total",
        "flavor": "Exactly 2 guests are in the room."
      }
    },
    {
      "id": "R2",
      "type": "forEachCount",
      "subject": "mirror",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 0
      },
      "presentation": {
        "title": "Mirror quiet zone",
        "flavor": "Every mirror excludes guests from adjacent cells."
      }
    },
    {
      "id": "R3",
      "type": "forEachCount",
      "subject": "bottle",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "guest",
      "count": {
        "op": "lte",
        "value": 1
      },
      "presentation": {
        "title": "Bottle cross limit",
        "flavor": "Every bottle has at most 1 guest in orthogonal cells."
      }
    }
