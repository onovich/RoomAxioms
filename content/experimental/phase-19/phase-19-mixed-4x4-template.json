{
  "board": {
    "width": 4,
    "height": 4
  },
  "allowedKinds": [
    "empty",
    "bottle",
    "bin",
    "mirror",
    "guest"
  ],
  "guestCount": 2,
  "rules": [
    {
      "id": "R1",
      "type": "globalCount",
      "target": "bin",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Bin total",
        "flavor": "Exactly 1 bin is in the room."
      }
    },
    {
      "id": "R2",
      "type": "globalCount",
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 2
      },
      "presentation": {
        "title": "Guest total",
        "flavor": "Exactly 2 guests are in the room."
      }
    },
    {
      "id": "R3",
      "type": "forEachCount",
      "subject": "bottle",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "bin",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Bottle cleanup",
        "flavor": "Every bottle sees exactly 1 bin orthogonally."
      }
    },
    {
      "id": "R4",
      "type": "forEachCount",
      "subject": "bin",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 0
      },
      "presentation": {
        "title": "Bin safe zone",
        "flavor": "Every bin excludes guests from adjacent cells."
      }
    },
    {
      "id": "R5",
      "type": "forEachCount",
      "subject": "mirror",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Mirror registration",
        "flavor": "Every mirror sees exactly 1 guest around it."
      }
    },
    {
      "id": "R6",
      "type": "forEachCount",
      "subject": "bottle",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 0
      },
      "presentation": {
        "title": "Bottle exclusion",
        "flavor": "Every bottle excludes guests from orthogonal cells."
      }
    }
  ],
  "initialRevealRange": {
    "min": 3,
    "max": 5
  },
  "caps": {
    "maxAttempts": 128,
    "maxNodes": 20000,
    "maxModels": 20000,
    "maxGuestLayouts": 100,
    "maxAccepted": 3
  },
  "artifactPolicy": "report-only",
  "template": {
    "idPrefix": "phase-19-mixed-4x4",
    "titlePrefix": "Phase 19 Mixed 4x4 Sample",
    "caseNamePrefix": "Phase 19 Mixed 4x4 Sample",
    "metadata": {
      "difficulty": 4,
      "tags": [
        "experimental",
        "phase-19",
        "sampled",
        "mixed-4x4"
      ],
      "author": "internal-phase-19",
      "status": "draft",
      "notes": "Private report-only mixed 4x4 sampling template for Phase 19."
    }
  }
}
