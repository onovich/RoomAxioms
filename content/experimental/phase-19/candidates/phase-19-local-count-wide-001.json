{
  "schemaVersion": 1,
  "id": "phase-19-local-count-wide-001",
  "title": "Local Count Wide Draft 001",
  "caseName": "Phase 19 Local Count Wide Draft 001",
  "board": {
    "width": 4,
    "height": 4
  },
  "allowedKinds": [
    "empty",
    "bottle",
    "bin",
    "mirror",
    "guest"
  ],
  "rules": [
    {
      "id": "R1",
      "type": "forEachCount",
      "subject": "bottle",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Bottle cross",
        "flavor": "Every bottle sees exactly 1 guest orthogonally."
      }
    },
    {
      "id": "R2",
      "type": "forEachCount",
      "subject": "mirror",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 0
      },
      "presentation": {
        "title": "Mirror quiet zone",
        "flavor": "Every mirror excludes guests from adjacent cells."
      }
    },
    {
      "id": "R3",
      "type": "forEachCount",
      "subject": "empty",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 0
      },
      "presentation": {
        "title": "Empty quiet line",
        "flavor": "Every empty room excludes guests from orthogonal cells."
      }
    },
    {
      "id": "R4",
      "type": "globalCount",
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 2
      },
      "presentation": {
        "title": "Guest total",
        "flavor": "Exactly 2 guests are in the room."
      }
    }
  ],
  "initialReveals": [
    "A1",
    "B1",
    "C1",
    "D2",
    "A4",
    "B4",
    "C4",
    "D4"
  ],
  "target": {
    "A1": "empty",
    "B1": "mirror",
    "C1": "empty",
    "D1": "empty",
    "A2": "empty",
    "B2": "bottle",
    "C2": "bottle",
    "D2": "empty",
    "A3": "bottle",
    "B3": "guest",
    "C3": "guest",
    "D3": "bottle",
    "A4": "bin",
    "B4": "bin",
    "C4": "bin",
    "D4": "bin"
  },
  "metadata": {
    "difficulty": 3,
    "tags": [
      "experimental",
      "phase-19",
      "candidate",
      "local-count"
    ],
    "author": "room-axioms-maintainers",
    "status": "draft",
    "notes": "Private Phase 19 local-count candidate; not shipped until promotion gates pass."
  }
}
