{
  "schemaVersion": 1,
  "id": "phase-19-intersection-wide-001",
  "title": "Intersection Wide Draft 001",
  "caseName": "Phase 19 Intersection Wide Draft 001",
  "board": {
    "width": 4,
    "height": 3
  },
  "allowedKinds": [
    "empty",
    "bottle",
    "bin",
    "mirror",
    "guest"
  ],
  "rules": [
    {
      "id": "R1",
      "type": "forEachCount",
      "subject": "mirror",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Mirror cross",
        "flavor": "Every mirror sees exactly 1 guest orthogonally."
      }
    },
    {
      "id": "R2",
      "type": "forEachCount",
      "subject": "bottle",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "lte",
        "value": 1
      },
      "presentation": {
        "title": "Bottle shared limit",
        "flavor": "Every bottle has at most 1 guest around it."
      }
    },
    {
      "id": "R3",
      "type": "forEachCount",
      "subject": "empty",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Empty cross",
        "flavor": "Every empty room sees exactly 1 guest orthogonally."
      }
    },
    {
      "id": "R4",
      "type": "globalCount",
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Guest total",
        "flavor": "Exactly 1 guest is in the room."
      }
    }
  ],
  "initialReveals": [
    "B1",
    "D1",
    "B2",
    "D2",
    "D3"
  ],
  "target": {
    "A1": "guest",
    "B1": "mirror",
    "C1": "bin",
    "D1": "bin",
    "A2": "empty",
    "B2": "bottle",
    "C2": "bin",
    "D2": "bin",
    "A3": "bin",
    "B3": "bottle",
    "C3": "bin",
    "D3": "bin"
  },
  "metadata": {
    "difficulty": 3,
    "tags": [
      "experimental",
      "phase-19",
      "candidate",
      "local-scope-intersection"
    ],
    "author": "room-axioms-maintainers",
    "status": "draft",
    "notes": "Private Phase 19 intersection candidate; not shipped until promotion gates pass."
  }
}
