{
  "schemaVersion": 1,
  "id": "phase-10-local-scope-intersection-001",
  "title": "Experimental Local Scope Intersection 001",
  "caseName": "Phase 10 Experimental - Local Scope Intersection 001",
  "board": {
    "width": 3,
    "height": 3
  },
  "allowedKinds": [
    "empty",
    "bottle",
    "bin",
    "mirror",
    "guest"
  ],
  "rules": [
    {
      "id": "R1",
      "type": "forEachCount",
      "subject": "mirror",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Mirror cross-check",
        "flavor": "Every mirror has exactly one guest in its orthogonal neighborhood."
      }
    },
    {
      "id": "R2",
      "type": "forEachCount",
      "subject": "bottle",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "lte",
        "value": 1
      },
      "presentation": {
        "title": "Bottle overlap cap",
        "flavor": "Every bottle has at most one guest in its adjacent neighborhood."
      }
    },
    {
      "id": "R3",
      "type": "forEachCount",
      "subject": "empty",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Empty room confirmation",
        "flavor": "Every empty room has exactly one guest in its orthogonal neighborhood."
      }
    }
  ],
  "initialReveals": [
    "B1",
    "B2"
  ],
  "target": {
    "A1": "guest",
    "B1": "mirror",
    "C1": "bin",
    "A2": "empty",
    "B2": "bottle",
    "C2": "bin",
    "A3": "bin",
    "B3": "bottle",
    "C3": "bin"
  },
  "metadata": {
    "difficulty": 3,
    "tags": [
      "experimental",
      "phase-10",
      "local-scope-intersection"
    ],
    "author": "internal-phase-10",
    "status": "draft",
    "notes": "Private experimental fixture for LOCAL_SCOPE_INTERSECTION validation. Not shipped in default web content."
  }
}
