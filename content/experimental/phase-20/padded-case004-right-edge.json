  "rules": [
    {
      "id": "R1",
      "type": "globalCount",
      "target": "bin",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Cleaning containers",
        "flavor": "There is exactly 1 bin in this room."
      }
    },
    {
      "id": "R2",
      "type": "globalCount",
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 2
      },
      "presentation": {
        "title": "Guest count",
        "flavor": "There are exactly 2 unregistered guests in this room."
      }
    },
    {
      "id": "R3",
      "type": "forEachCount",
      "subject": "bottle",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "bin",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Bottle cleanup",
        "flavor": "Each bottle has exactly 1 bin in its orthogonal neighborhood."
      }
    },
    {
      "id": "R4",
      "type": "forEachCount",
      "subject": "bin",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 0
      },
      "presentation": {
        "title": "Safe cleanup zone",
        "flavor": "Each bin has no guests in its adjacent neighborhood."
      }
    },
    {
      "id": "R5",
      "type": "forEachCount",
      "subject": "mirror",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Mirror registration",
        "flavor": "Each mirror has exactly 1 guest in its adjacent neighborhood."
      }
    },
    {
      "id": "R6",
      "type": "forEachCount",
      "subject": "bottle",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 0
      },
      "presentation": {
        "title": "Bottle exclusion",
        "flavor": "Each bottle has no guests in its orthogonal neighborhood."
      }
    }
  ],
