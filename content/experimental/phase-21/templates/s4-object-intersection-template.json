{
  "skeletonId": "S4",
  "skeletonName": "Object Intersection Then Guest Exclusion",
  "board": {
    "width": 4,
    "height": 4
  },
  "allowedKinds": [
    "empty",
    "bottle",
    "bin",
    "mirror",
    "guest"
  ],
  "guestCount": 2,
  "rules": [
    {
      "id": "R1",
      "type": "globalCount",
      "target": "mirror",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Mirror total",
        "flavor": "Exactly 1 mirror is in this room."
      }
    },
    {
      "id": "R2",
      "type": "globalCount",
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 2
      },
      "presentation": {
        "title": "Guest total",
        "flavor": "Exactly 2 guests are in this room."
      }
    },
    {
      "id": "R3",
      "type": "forEachCount",
      "subject": "bottle",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "mirror",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Bottle mirror cross",
        "flavor": "Every bottle sees exactly 1 mirror orthogonally."
      }
    },
    {
      "id": "R4",
      "type": "forEachCount",
      "subject": "mirror",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 0
      },
      "presentation": {
        "title": "Mirror quiet ring",
        "flavor": "No guest is adjacent to the mirror."
      }
    },
    {
      "id": "R5",
      "type": "forEachCount",
      "subject": "bin",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Bin guest cross",
        "flavor": "Every bin sees exactly 1 guest orthogonally."
      }
    },
    {
      "id": "R6",
      "type": "forEachCount",
      "subject": "empty",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "lte",
        "value": 1
      },
      "presentation": {
        "title": "Empty ring limit",
        "flavor": "Every empty room has at most 1 guest around it."
      }
    }
  ],
  "initialRevealRange": {
    "min": 4,
    "max": 6
  },
  "caps": {
    "maxAttempts": 192,
    "maxNodes": 20000,
    "maxModels": 20000,
    "maxGuestLayouts": 100,
    "maxAccepted": 4
  },
  "artifactPolicy": "report-only",
  "template": {
    "idPrefix": "phase-21-s4-object-intersection",
    "titlePrefix": "Phase 21 S4 Object Intersection Candidate",
    "caseNamePrefix": "Phase 21 S4 Object Intersection",
    "metadata": {
      "difficulty": 4,
      "tags": [
        "experimental",
        "phase-21",
        "s4",
        "mixed-object"
      ],
      "author": "internal-phase-21",
      "status": "draft",
      "notes": "Private report-only template for S4 object-intersection exploration."
    }
  }
}
