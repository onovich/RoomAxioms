  "guestCount": 2,
  "rules": [
    {
      "id": "R1",
      "type": "globalCount",
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 2
      },
      "presentation": {
        "title": "Guest total",
        "flavor": "Exactly 2 guests are in this room."
      }
    },
    {
      "id": "R2",
      "type": "forEachCount",
      "subject": "mirror",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Mirror cross",
        "flavor": "Every mirror sees exactly 1 guest orthogonally."
      }
    },
    {
      "id": "R3",
      "type": "forEachCount",
      "subject": "bottle",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "lte",
        "value": 1
      },
      "presentation": {
        "title": "Bottle shared limit",
        "flavor": "Every bottle has at most 1 guest around it."
      }
    },
    {
      "id": "R4",
      "type": "forEachCount",
      "subject": "empty",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Empty cross",
        "flavor": "Every empty room sees exactly 1 guest orthogonally."
      }
    },
    {
      "id": "R5",
      "type": "forEachCount",
      "subject": "bin",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 0
      },
      "presentation": {
        "title": "Bin safe zone",
        "flavor": "No guest is adjacent to a bin."
      }
    }
  ],
