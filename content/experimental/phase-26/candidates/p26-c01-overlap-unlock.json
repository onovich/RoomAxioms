{
  "schemaVersion": 1,
  "id": "p26-c01-overlap-unlock",
  "title": "Phase 26 Candidate 01 Overlap Unlock",
  "caseName": "Phase 26 - 重叠线索候选 01",
  "board": {
    "width": 4,
    "height": 4
  },
  "allowedKinds": [
    "empty",
    "bottle",
    "bin",
    "mirror",
    "guest"
  ],
  "rules": [
    {
      "id": "R1",
      "type": "globalCount",
      "target": "bin",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "垃圾桶总数",
        "flavor": "房间里恰好有 1 个垃圾桶。"
      }
    },
    {
      "id": "R2",
      "type": "globalCount",
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 2
      },
      "presentation": {
        "title": "访客总数",
        "flavor": "房间里恰好有 2 名访客。"
      }
    },
    {
      "id": "R3",
      "type": "forEachCount",
      "subject": "bottle",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "bin",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "酒瓶旁的垃圾桶",
        "flavor": "每个酒瓶上下左右邻格里，必有 1 个垃圾桶。"
      }
    },
    {
      "id": "R4",
      "type": "forEachCount",
      "subject": "bin",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 0
      },
      "presentation": {
        "title": "垃圾桶周围",
        "flavor": "每个垃圾桶周围一圈，没有访客。"
      }
    },
    {
      "id": "R5",
      "type": "forEachCount",
      "subject": "mirror",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "镜子周围",
        "flavor": "每面镜子周围一圈，必有 1 名访客。"
      }
    },
    {
      "id": "R6",
      "type": "forEachCount",
      "subject": "bottle",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 0
      },
      "presentation": {
        "title": "酒瓶十字",
        "flavor": "每个酒瓶上下左右邻格里，没有访客。"
      }
    },
    {
      "id": "R7",
      "type": "scopeOverlapCount",
      "left": {
        "kind": "line",
        "scope": {
          "kind": "row",
          "index": 0
        }
      },
      "right": {
        "kind": "line",
        "scope": {
          "kind": "column",
          "index": 3
        }
      },
      "mode": "union",
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "第一排与 D 列",
        "flavor": "A1、B1、C1、D1、D2、D3、D4 这 7 格里，恰好有 1 名访客。"
      }
    }
  ],
  "initialReveals": [
    "B1",
    "A2",
    "C2"
  ],
  "target": {
    "A1": "empty",
    "B1": "bottle",
    "C1": "mirror",
    "D1": "guest",
    "A2": "bottle",
    "B2": "bin",
    "C2": "bottle",
    "D2": "empty",
    "A3": "mirror",
    "B3": "empty",
    "C3": "mirror",
    "D3": "empty",
    "A4": "empty",
    "B4": "guest",
    "C4": "empty",
    "D4": "empty"
  },
  "metadata": {
    "difficulty": 4,
    "tags": [
      "experimental",
      "phase-26",
      "scope-overlap-count",
      "private"
    ],
    "author": "room-axioms-maintainers",
    "status": "draft",
    "notes": "Round 5 serious candidate for P26-S1. This repair attempt tests whether an explicit row/column union scopeOverlapCount can coexist with a known explainable classic chain; clone and rule-contribution gates are expected to decide whether it is useful."
  }
}
