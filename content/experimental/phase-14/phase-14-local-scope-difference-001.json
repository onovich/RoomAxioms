{
  "schemaVersion": 1,
  "id": "phase-14-local-scope-difference-001",
  "title": "Phase 14 Experimental - Retained Difference 001",
  "caseName": "Phase 14 Experimental - Retained Difference 001",
  "board": {
    "width": 3,
    "height": 3
  },
  "allowedKinds": [
    "empty",
    "bottle",
    "mirror",
    "guest"
  ],
  "rules": [
    {
      "id": "R1",
      "type": "forEachCount",
      "subject": "bottle",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 2
      },
      "presentation": {
        "title": "Bottle cross count",
        "flavor": "Each bottle has exactly 2 guests in orthogonal neighbors."
      }
    },
    {
      "id": "R2",
      "type": "forEachCount",
      "subject": "mirror",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Mirror ring count",
        "flavor": "Each mirror has exactly 1 guest around it."
      }
    },
    {
      "id": "R3",
      "type": "globalCount",
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 2
      },
      "presentation": {
        "title": "Guest total",
        "flavor": "There are exactly 2 guests in the room."
      }
    }
  ],
  "initialReveals": [
    "A1",
    "B1",
    "C1",
    "B2"
  ],
  "target": {
    "A1": "empty",
    "B1": "mirror",
    "C1": "empty",
    "A2": "empty",
    "B2": "bottle",
    "C2": "guest",
    "A3": "empty",
    "B3": "guest",
    "C3": "empty"
  },
  "metadata": {
    "difficulty": 3,
    "tags": [
      "experimental",
      "phase-14",
      "local-scope-difference",
      "retention-check"
    ],
    "author": "internal-phase-14",
    "status": "draft",
    "notes": "Private retained-difference candidate. Not shipped in default web content."
  }
}
