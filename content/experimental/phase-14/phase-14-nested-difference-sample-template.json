{
  "board": {
    "width": 4,
    "height": 3
  },
  "allowedKinds": [
    "empty",
    "bottle",
    "mirror",
    "guest"
  ],
  "guestCount": 2,
  "rules": [
    {
      "id": "R1",
      "type": "forEachCount",
      "subject": "bottle",
      "scope": {
        "kind": "orthogonal"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 1
      },
      "presentation": {
        "title": "Bottle cross count",
        "flavor": "Each bottle has exactly 1 guest in orthogonal neighbors."
      }
    },
    {
      "id": "R2",
      "type": "forEachCount",
      "subject": "mirror",
      "scope": {
        "kind": "adjacent"
      },
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 0
      },
      "presentation": {
        "title": "Mirror quiet zone",
        "flavor": "Each mirror has exactly 0 guests around it."
      }
    },
    {
      "id": "R3",
      "type": "globalCount",
      "target": "guest",
      "count": {
        "op": "eq",
        "value": 2
      },
      "presentation": {
        "title": "Guest total",
        "flavor": "There are exactly 2 guests in the room."
      }
    }
  ],
  "initialRevealRange": {
    "min": 3,
    "max": 5
